# Required — customize for your app
VITE_APP_NAME=My Solid App
VITE_APP_SHORT_NAME=SolidApp
VITE_APP_DESCRIPTION=A web application that stores data on your Solid Pod
VITE_APP_DOMAIN=localhost:5173
VITE_CLIENT_ID_URL=https://YOUR-APP-DOMAIN/client-id.json

# Optional branding
VITE_THEME_COLOR=#1A73E8
VITE_BG_COLOR=#F8F9FA

# Optional support
VITE_SUPPORT_EMAIL=support@example.com

# Optional — set to 'true' to enable mock mode (no Solid Pod needed)
# VITE_MOCK_MODE=true
